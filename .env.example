# Dominik's Dashboard — Supabase credentials.
#
# NOTE: the static frontend has no build step, so it cannot read env vars —
# it takes these two values from constants in assets/js/supabase.js instead.
# This file documents them for the future /api serverless phase (Vercel env vars).

# Your Supabase project URL (Project settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# The public "anon" API key (safe for the browser; protect data with RLS)
SUPABASE_ANON_KEY=your-anon-key
